# Database
POSTGRES_DB=lighthouse
POSTGRES_USER=lighthouse
POSTGRES_PASSWORD=changeme_in_production

# Backend
DATABASE_URL=postgresql+asyncpg://lighthouse:changeme_in_production@db:5432/lighthouse
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# CORS (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Environment
ENVIRONMENT=development

# Demo data — set to true to pre-populate with Savanna Commercial Bank scenario
SEED_DEMO_DATA=false
